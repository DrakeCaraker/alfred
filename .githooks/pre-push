#!/usr/bin/env bash
# Pre-push hook: branch safety and file guards
# Install: git config core.hooksPath .githooks
# Reads config from .claude/alfred.yaml if available

# Read config from alfred.yaml (with sensible defaults)
CONFIG="scripts/alfred-config.sh"
MAIN_BRANCH="main"
if [ -x "$CONFIG" ]; then
    MAIN_BRANCH=$("$CONFIG" git.main_branch main 2>/dev/null)
fi

# --- 1. Block direct pushes to main ---
current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ "$current_branch" = "$MAIN_BRANCH" ] || [ "$current_branch" = "master" ]; then
    echo "BLOCKED: Direct push to $MAIN_BRANCH/master is not allowed."
    echo "  Create a feature branch: git checkout -b feat/<topic>"
    echo "  To override (emergency only): git push --no-verify"
    exit 1
fi

# --- 2. Drift warning (non-blocking) ---
if [ "$current_branch" != "HEAD" ]; then
    git fetch origin "$MAIN_BRANCH" --quiet 2>/dev/null
    if git rev-parse "origin/$MAIN_BRANCH" >/dev/null 2>&1; then
        behind=$(git rev-list --count "HEAD..origin/$MAIN_BRANCH" 2>/dev/null || echo 0)
        if [ "$behind" -gt 0 ]; then
            echo "WARNING: Branch '$current_branch' is $behind commit(s) behind origin/$MAIN_BRANCH."
            echo "  Consider rebasing: git rebase origin/$MAIN_BRANCH"
            echo ""
        fi
    fi
fi

# --- 3. Security audit (blocking) ---
if [ -x "scripts/audit.sh" ]; then
    if ! bash scripts/audit.sh >/dev/null 2>&1; then
        echo ""
        echo "BLOCKED: Security audit failed. Run 'make audit' for details."
        echo "  To override: git push --no-verify"
        exit 1
    fi
fi

# --- 4. File checks: block binaries and large files (blocking) ---
# Read from alfred.yaml with defaults
CONFIGURED_MAX_MB=10
CONFIGURED_EXTENSIONS="pkl|pt|pth|h5|joblib|ckpt|safetensors"
if [ -x "$CONFIG" ]; then
    CONFIGURED_MAX_MB=$("$CONFIG" max_file_size_mb 10 2>/dev/null)
    ext_raw=$("$CONFIG" blocked_extensions "" 2>/dev/null)
    if [ -n "$ext_raw" ]; then
        # alfred-config returns pipe-separated, strip leading dots
        CONFIGURED_EXTENSIONS=$(echo "$ext_raw" | sed 's/\.//g')
    fi
fi
MAX_SIZE=$((CONFIGURED_MAX_MB * 1048576))
BLOCKED_EXTENSIONS="$CONFIGURED_EXTENSIONS"
ERRORS=0

while read _local_ref local_sha _remote_ref remote_sha; do
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        range="$local_sha"
    else
        range="$remote_sha..$local_sha"
    fi

    files=$(git diff --name-only --diff-filter=ACM "$range" 2>/dev/null)

    for file in $files; do
        # PII scan for .pilot/ files
        if echo "$file" | grep -q '^\.pilot/' && [ "$(basename "$file")" != ".gitkeep" ]; then
            if [ -x "scripts/pii-scanner.sh" ]; then
                if echo "$file" | grep -q '\.json$'; then
                    scripts/pii-scanner.sh "$file" 2>&1
                elif echo "$file" | grep -q '\.md$' && echo "$file" | grep -q '^\.pilot/feedback/'; then
                    scripts/pii-scanner.sh --feedback "$file" 2>&1
                else
                    scripts/pii-scanner.sh "$file" 2>&1
                fi
                if [ $? -eq 1 ]; then
                    echo "BLOCKED: PII found in $file"
                    ERRORS=$((ERRORS + 1))
                fi
            fi
        fi

        # Block binary artifact extensions
        if echo "$file" | grep -qE "\.($BLOCKED_EXTENSIONS)$"; then
            echo "BLOCKED: $file is a binary artifact. Remove it from the commit."
            ERRORS=$((ERRORS + 1))
            continue
        fi

        # Block files >10MB
        if git cat-file -e "$local_sha:$file" 2>/dev/null; then
            size=$(git cat-file -s "$local_sha:$file" 2>/dev/null || echo 0)
            if [ "$size" -gt "$MAX_SIZE" ] 2>/dev/null; then
                echo "BLOCKED: $file is $((size / 1024))KB (limit: $((MAX_SIZE / 1024))KB)"
                ERRORS=$((ERRORS + 1))
            fi
        fi
    done
done

if [ "$ERRORS" -gt 0 ]; then
    echo ""
    echo "$ERRORS file(s) blocked. To override: git push --no-verify"
    exit 1
fi
exit 0
