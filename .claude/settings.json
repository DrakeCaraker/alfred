{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash",
            "Read",
            "Write",
            "Edit",
            "Glob",
            "Grep",
            "Agent",
            "WebFetch",
            "WebSearch"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/format-on-write.sh",
                        "timeout": 10
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/session-start.sh"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/session-bookmark.sh",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/feedback-capture.sh",
                        "timeout": 5
                    },
                    {
                        "type": "command",
                        "command": ".claude/hooks/pilot-telemetry.sh",
                        "timeout": 5
                    }
                ]
            }
        ],
        "PreCompact": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": ".claude/hooks/pre-compact.sh"
                    }
                ]
            }
        ]
    }
}
